{
  "name": "@teacheros/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/client.js",
  "types": "src/client.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noCheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
