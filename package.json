{
  "name": "teacher-platform-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "set -a; . ./.env; set +a; npm-run-all -p dev:web dev:api dev:worker",
    "dev:web": "set -a; . ./.env; set +a; npm --workspace @teacheros/web run dev",
    "dev:api": "set -a; . ./.env; set +a; npm --workspace @teacheros/api run dev",
    "dev:worker": "set -a; . ./.env; set +a; npm --workspace @teacheros/worker run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "pretest": "npm --workspace @teacheros/contracts run build && npm --workspace @teacheros/db run build",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ops:backup:db": "bash ops/scripts/backup_postgres.sh",
    "ops:restore:db": "bash ops/scripts/restore_postgres.sh",
    "ops:backup:s3": "bash ops/scripts/backup_s3_materials.sh",
    "ops:restore:s3": "bash ops/scripts/restore_s3_materials.sh",
    "ops:cutover:preflight": "bash ops/scripts/cutover_preflight.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.13",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.3"
  }
}
