# Shared
NODE_ENV=development
LOG_LEVEL=info

# API runtime
API_PORT=3001
API_BASE_URL=http://localhost:3001
REQUEST_ID_HEADER=x-request-id

# Clerk (auth)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_KEY=your_clerk_jwt_key
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teacheros
REDIS_URL=redis://localhost:6379

# S3-compatible private object storage + signed URLs
# Free pilot default: Cloudflare R2.
S3_REGION=auto
S3_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
S3_FORCE_PATH_STYLE=true
S3_BUCKET=teacheros-materials
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key

# AI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_PARSE_SCHEDULE=gpt-4o-mini
OPENAI_MODEL_GENERATE_SEGMENTS=gpt-4o
OPENAI_MODEL_CONTINUITY=gpt-4o

# Sentry
SENTRY_DSN=

# Web
VITE_API_BASE_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_SENTRY_DSN=
